<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="MailApp">

  <Id>12345678-1234-1234-1234-123456789012</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Demo</ProviderName>
  <DisplayName DefaultValue="Domain Checker"/>
  <Description DefaultValue="Checks external recipients"/>

  <Permissions>ReadItem</Permissions>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.10"/>
    </Sets>
  </Requirements>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
                    xsi:type="VersionOverridesV1_1">

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="Events">
            <Event Type="OnMessageRecipientsChanged"
                   FunctionExecution="synchronous"
                   FunctionName="onRecipientsChanged"/>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Urls xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0">
        <bt:Url id="functionFile" DefaultValue="https://ddrozd-arch.github.io/Addin/index.html"/>
      </bt:Urls>
    </Resources>

  </VersionOverrides>
</OfficeApp>
