<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <system.web>
    <globalization
        fileEncoding="utf-8"
        requestEncoding="utf-8"
        responseEncoding="utf-8"
        culture="pl-PL"
        uiCulture="pl-PL" />
    <compilation debug="false" />
  </system.web>

  <system.webServer>

    <!-- MIME types wymagane przez Office.js -->
    <staticContent>
      <mimeMap fileExtension=".xml" mimeType="text/xml" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
      <mimeMap fileExtension=".map" mimeType="application/json" />
      <mimeMap fileExtension=".html" mimeType="text/html" />
      <mimeMap fileExtension=".css" mimeType="text/css" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <mimeMap fileExtension=".png" mimeType="image/png" />
      <mimeMap fileExtension=".ico" mimeType="image/x-icon" />
    </staticContent>

    <!-- Wyłączenie kompresji XML (ważne dla manifestu) -->
    <urlCompression doStaticCompression="false" doDynamicCompression="false" />

    <!-- Nagłówki bezpieczeństwa + CSP -->
    <httpProtocol>
      <customHeaders>

        <!-- CSP zgodny z Outlook/OWA -->
        <add name="Content-Security-Policy" value="
          default-src 'self';
          script-src 'self' https://appsforoffice.microsoft.com 'unsafe-inline';
          style-src 'self' 'unsafe-inline';
          img-src 'self' data:;
          font-src 'self';
          connect-src 'self';
          frame-src https://outlook.office.com https://outlook.office365.com https://outlook.live.com https://*.office.com https://*.office365.com;
          frame-ancestors https://outlook.office.com https://outlook.office365.com https://outlook.live.com https://*.office.com https://*.office365.com;
          object-src 'none';
          base-uri 'self';
          form-action 'self';
        " />

        <!-- CORS (jeśli OWA z innej domeny) -->
        <add name="Access-Control-Allow-Origin" value="*" />
        <add name="Access-Control-Allow-Methods" value="GET, OPTIONS" />
        <add name="Access-Control-Allow-Headers" value="Content-Type, Authorization" />

        <!-- Dodatkowe nagłówki bezpieczeństwa -->
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="no-referrer" />
        <add name="X-Frame-Options" value="ALLOW-FROM https://outlook.office.com" />
      </customHeaders>
    </httpProtocol>

    <!-- HTTPS -->
    <security>
      <access sslFlags="Ssl, SslNegotiateCert" />
    </security>

    <!-- Obsługa SPA/taskpane -->
    <handlers>
      <add name="StaticFile" path="*" verb="*" modules="StaticFileModule" resourceType="Either" requireAccess="Read" />
    </handlers>

  </system.webServer>

</configuration>
