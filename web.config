<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <httpProtocol>
      <customHeaders>

        <!-- 🔐 Content Security Policy -->
        <add name="Content-Security-Policy" value="
          default-src 'self' https:;
          script-src 'self' https://appsforoffice.microsoft.com https://*.office.com https://*.office365.com https://*.outlook.com https: 'unsafe-inline' 'unsafe-eval';
          style-src 'self' https: 'unsafe-inline';
          img-src 'self' data: https:;
          font-src 'self' data: https:;
          connect-src 'self' https:;
          frame-ancestors https://*.office.com https://*.office365.com https://*.outlook.com;
        " />

        <!-- ⚠️ X-Frame-Options (ważne!) -->
        <!-- NIE ustawiaj DENY ani SAMEORIGIN -->
        <add name="X-Frame-Options" value="ALLOW-FROM https://outlook.office.com" />

        <!-- Inne bezpieczne nagłówki -->
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="no-referrer-when-downgrade" />

      </customHeaders>
    </httpProtocol>

    <!-- Obsługa MIME (ważne dla JS/CSS/SVG) -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />

      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />

      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />

      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <!-- CORS (opcjonalnie, jeśli masz API) -->
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="*" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, OPTIONS" />
        <add name="Access-Control-Allow-Headers" value="Content-Type" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>